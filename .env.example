# Copy this file to ".env" and fill in the values. ".env" is gitignored.

# Required: Tavily search API key — https://tavily.com/
TAVILY_API_KEY=your-tavily-api-key

# Required for the default model (openai:gpt-4o-mini) — https://platform.openai.com/
OPENAI_API_KEY=your-openai-api-key

# Optional: only if you switch to a non-OpenAI model in config.py
# ANTHROPIC_API_KEY=your-anthropic-api-key
# GOOGLE_API_KEY=your-google-api-key
